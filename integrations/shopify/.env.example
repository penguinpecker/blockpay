# Shopify app credentials (from your Partner dashboard or `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Comma-separated OAuth scopes. Must match shopify.app.toml.
SCOPES=read_products,write_orders

# The public HTTPS URL of your dev tunnel (e.g. https://your-shop.trycloudflare.com).
# Shopify CLI sets this automatically when you run `shopify app dev`.
HOST=
SHOPIFY_APP_URL=

# Where the BlockPay-hosted checkout lives.
BLOCKPAY_APP_URL=https://blockpay-six.vercel.app

# Optional: local Prisma database. Default is SQLite at file:dev.sqlite.
DATABASE_URL="file:./prisma/dev.sqlite"

# Optional: override the storefront myshopify.com domain validator
# SHOP_CUSTOM_DOMAIN=
