{% comment %}
  BlockPay — Pay with crypto CTA
  -------------------------------
  Drop this block onto the cart page (Online Store > Themes > Customize > Cart).
  It renders a button that redirects the shopper to BlockPay-hosted checkout,
  carrying the shop domain and (when available) the merchant slug so BlockPay
  can resolve the merchant's settlement settings.
{% endcomment %}

{%- liquid
  assign blockpay_base = block.settings.blockpay_app_url | default: 'https://blockpay-six.vercel.app'
  assign merchant_slug = block.settings.merchant_slug | strip
  assign shop_domain = shop.permanent_domain
  assign button_label = block.settings.button_label | default: 'Pay with crypto via BlockPay'
  assign helper_text = block.settings.helper_text | default: 'Settle in USDC. Powered by BlockPay.'

  if merchant_slug == blank
    assign shop_handle = shop_domain | split: '.myshopify.com' | first
    assign merchant_slug = shop_handle | downcase
  endif

  assign cart_total_cents = cart.total_price
  assign cart_currency = cart.currency.iso_code
-%}

<div class="blockpay-cta" {{ block.shopify_attributes }}>
  <a
    class="blockpay-cta__button"
    href="{{ blockpay_base }}/pay/{{ merchant_slug }}?source=shopify&shop={{ shop_domain | url_encode }}&cart_total={{ cart_total_cents }}&currency={{ cart_currency }}"
    target="_top"
    rel="noopener"
    data-blockpay-cta
    data-blockpay-shop="{{ shop_domain }}"
    data-blockpay-slug="{{ merchant_slug }}"
  >
    <span class="blockpay-cta__icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 7l8-4 8 4-8 4-8-4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        <path d="M4 12l8 4 8-4" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        <path d="M4 17l8 4 8-4" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
    </span>
    <span class="blockpay-cta__label">{{ button_label }}</span>
  </a>
  {%- if helper_text != blank -%}
    <p class="blockpay-cta__helper">{{ helper_text }}</p>
  {%- endif -%}
</div>

<style>
  .blockpay-cta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1rem 0;
    font-family: inherit;
  }
  .blockpay-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    border-radius: 10px;
    background: {{ block.settings.button_bg | default: '#0b0f17' }};
    color: {{ block.settings.button_fg | default: '#ffffff' }};
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.08);
    transition: transform 120ms ease, opacity 120ms ease;
  }
  .blockpay-cta__button:hover { opacity: 0.92; transform: translateY(-1px); }
  .blockpay-cta__button:active { transform: translateY(0); }
  .blockpay-cta__helper {
    margin: 0;
    font-size: 0.85rem;
    opacity: 0.7;
  }
</style>

{% schema %}
{
  "name": "BlockPay checkout CTA",
  "target": "section",
  "stylesheet": "checkout-cta.css",
  "enabled_on": {
    "templates": ["cart", "product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Pay with crypto via BlockPay"
    },
    {
      "type": "text",
      "id": "helper_text",
      "label": "Helper text",
      "default": "Settle in USDC. Powered by BlockPay."
    },
    {
      "type": "text",
      "id": "merchant_slug",
      "label": "Merchant slug (optional)",
      "info": "Leave blank to use your shop subdomain as the slug."
    },
    {
      "type": "url",
      "id": "blockpay_app_url",
      "label": "BlockPay app URL",
      "default": "https://blockpay-six.vercel.app"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#0b0f17"
    },
    {
      "type": "color",
      "id": "button_fg",
      "label": "Button text",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
