{
  "name": "@blockpay/shopify",
  "version": "0.1.0",
  "description": "BlockPay SDK for Shopify themes and apps — convert carts to crypto invoices, sync Shopify orders, and bridge BlockPay webhooks to the Shopify Admin API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "require": "./dist/theme.cjs"
    },
    "./theme/browser": {
      "types": "./dist/theme.browser.d.ts",
      "import": "./dist/theme.browser.js",
      "require": "./dist/theme.browser.cjs"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "require": "./dist/app.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js",
      "require": "./dist/webhooks.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "blockpay",
    "shopify",
    "shopify-app",
    "shopify-theme",
    "crypto",
    "stablecoin",
    "USDC",
    "EURC",
    "payments",
    "checkout"
  ],
  "author": "BlockPay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blockpay/shopify-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/blockpay/shopify-sdk/issues"
  },
  "homepage": "https://blockpay-six.vercel.app/docs/shopify",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@blockpay/checkout": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@blockpay/checkout": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.5.0",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
