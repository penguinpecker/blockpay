{
    "name": "blockpay/woocommerce",
    "description": "BlockPay PHP SDK for WordPress and WooCommerce integrations. Create invoices, generate payment links, verify webhooks, and map BlockPay events onto WooCommerce orders.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "blockpay",
        "woocommerce",
        "wordpress",
        "payments",
        "usdc",
        "crypto",
        "sdk"
    ],
    "homepage": "https://blockpay-six.vercel.app",
    "support": {
        "source": "https://github.com/blockpay/woocommerce-sdk",
        "issues": "https://github.com/blockpay/woocommerce-sdk/issues"
    },
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "phpstan/phpstan": "^1"
    },
    "autoload": {
        "psr-4": {
            "BlockPay\\WooCommerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlockPay\\WooCommerce\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
